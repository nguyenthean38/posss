# ─── SePay Payment Gateway ─────────────────────────────────────────────────
# SEPAY_ENV: production = tiền thật (pay.sepay.vn); bất kỳ giá trị khác = sandbox
# QUAN TRỌNG — trước khi set SEPAY_ENV=production:
#   1. Thay SEPAY_MERCHANT_ID + SEPAY_SECRET_KEY bằng credential PRODUCTION từ my.sepay.vn
#   2. Cập nhật IPN trên SePay dashboard: https://<domain>/backend/index.php/api/pos/sepay/ipn
#   3. Đổi domain/IPN: đổi SEPAY_*_URL bên dưới + cập nhật allowedOrigins trong backend/index.php
#   4. Sau khi đổi key/URL: docker compose up -d backend
#   5. KHÔNG commit file này vào Git sau khi điền key thật
SEPAY_MERCHANT_ID=SP-LIVE-NT533773
SEPAY_SECRET_KEY=spsk_live_PUbyes4mmM1eto2cvrhE9kLoaH54Ta44

SEPAY_ENV=production
# URL redirect sau thanh toán — phải dùng HTTPS và trùng domain/host mà nhân viên POS đang mở
# Nếu dùng ngrok: cập nhật 3 URL này mỗi khi ngrok subdomain thay đổi
SEPAY_SUCCESS_URL=https://unconsonant-alycia-pawkily.ngrok-free.dev/frontend/pos.html?sepay=success
SEPAY_ERROR_URL=https://unconsonant-alycia-pawkily.ngrok-free.dev/frontend/pos.html?sepay=error
SEPAY_CANCEL_URL=https://unconsonant-alycia-pawkily.ngrok-free.dev/frontend/pos.html?sepay=cancel
# VietQR — TK nhận tiền hiển thị trên QR modal POS
SEPAY_BANK_CODE=ICB
SEPAY_ACCOUNT_NUMBER=107879864628
SEPAY_ACCOUNT_NAME=NGUYEN THE AN