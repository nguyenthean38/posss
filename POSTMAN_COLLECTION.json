            },
            "url": { "raw": "{{baseUrl}}/api/profile", "host": ["{{baseUrl}}"], "path": ["api", "profile"] }
          }
        },
        {
          "name": "[PROFILE] Upload Avatar",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Image", "type": "file", "src": "/path/to/avatar.png" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/profile/avatar", "host": ["{{baseUrl}}"], "path": ["api", "profile", "avatar"] }
          }
        }
      ]
    },
