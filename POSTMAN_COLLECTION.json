{
  "info": {
    "name": "PhoneStore POS API",
    "_postman_id": "phonestore-pos-v1",
    "description": "Bộ API đầy đủ cho hệ thống PhoneStore POS.\n\n**Hướng dẫn sử dụng:**\n1. Import file này vào Postman.\n2. Chỉnh biến `baseUrl` trong Collection Variables nếu cần.\n3. Chạy request **[AUTH] Login** trước – cookie `PHPSESSID` sẽ tự động được lưu.\n4. Tất cả request sau sẽ dùng lại cookie đó.\n\nMặc định: `admin@gmail.com / admin`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080/backend/index.php", "type": "string" },
    { "key": "adminEmail", "value": "admin@gmail.com",                          "type": "string" },
    { "key": "adminPwd",   "value": "admin",                                    "type": "string" },
    { "key": "staffEmail", "value": "staff@gmail.com",                          "type": "string" },
    { "key": "staffPwd",   "value": "admin",                                    "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "[AUTH] Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token or role', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j).to.have.property('role');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPwd}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "[AUTH] Login (Staff)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPwd}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "[AUTH] Me (current user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has email', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j).to.have.property('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "[AUTH] Verify Token (first login step 1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newstaff@gmail.com\",\n  \"token\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-token", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-token"] }
          }
        },
        {
          "name": "[AUTH] First Login (set password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newstaff@gmail.com\",\n  \"token\": \"123456\",\n  \"password\": \"NewPass@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/first-login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "first-login"] }
          }
        },
        {
          "name": "[AUTH] Init Password (after first login session)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_password\": \"NewPass@123\",\n  \"confirm_password\": \"NewPass@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/init-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "init-password"] }
          }
        },
        {
          "name": "[AUTH] Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"admin\",\n  \"new_password\": \"NewPass@123\",\n  \"confirm_password\": \"NewPass@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "change-password"] }
          }
        },
        {
          "name": "[AUTH] Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
