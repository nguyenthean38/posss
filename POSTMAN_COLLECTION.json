                  "pm.test('Message ok', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.message).to.include('thành công');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
