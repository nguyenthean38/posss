# Copy thành .env (gốc project hoặc backend/) — không commit.
# OpenRouter: https://openrouter.ai/keys — model: https://openrouter.ai/models

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Tùy chọn (Referer / X-Title cho OpenRouter)
OPENROUTER_APP_URL=http://localhost:8080
OPENROUTER_APP_NAME=PhoneStore POS
