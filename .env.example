# Copy thành .env (gốc project hoặc backend/) — không commit.
# OpenRouter: https://openrouter.ai/keys — model: https://openrouter.ai/models

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Tùy chọn (Referer / X-Title cho OpenRouter)
OPENROUTER_APP_URL=http://localhost:8080
OPENROUTER_APP_NAME=PhoneStore POS

# SePay Payment Gateway — https://developer.sepay.vn
# Chạy migration (theo thứ tự): backend/migrations/004_sepay_pos_payment.sql rồi 005_sepay_checkout_session.sql
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
# sandbox | production
SEPAY_ENV=sandbox
# URL khách được redirect sau thanh toán (tùy chọn; mặc định backend trỏ về pos.html)
SEPAY_SUCCESS_URL=http://127.0.0.1:8080/frontend/pos.html?sepay=success
SEPAY_ERROR_URL=http://127.0.0.1:8080/frontend/pos.html?sepay=error
SEPAY_CANCEL_URL=http://127.0.0.1:8080/frontend/pos.html?sepay=cancel
# VietQR — STK nhận (img.vietqr.io)
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
# VietinBank + SePay: nội dung CK phải bắt đầu SEVQR; để trống = không thêm tiền tố
SEPAY_TRANSFER_PREFIX=SEVQR
